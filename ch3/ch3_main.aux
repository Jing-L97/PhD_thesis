\@writefile{lot}{\contentsline {table}{\numberline {3.2}{\ignorespaces Frequency-stratified syntactic contrast accuracy. kNN-LM ($k=1$, $\tau =3$,sequence-level retrieval) narrows the performance gap across all phenomena and both pretraining scales but does not fully close it. Bold indicates improvement over baseline.}}{30}{table.caption.51}\protected@file@percent }
\newlabel{tab:frequency_effects}{{3.2}{30}{Frequency-stratified syntactic contrast accuracy. kNN-LM ($k=1$, $\tau =3$,sequence-level retrieval) narrows the performance gap across all phenomena and both pretraining scales but does not fully close it. Bold indicates improvement over baseline}{table.caption.51}{}}
\newlabel{tab:frequency_effects@cref}{{[table][2][3]3.2}{[1][30][]30}{}{}{}}
