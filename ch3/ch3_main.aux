\newlabel{sec:multidimensional_binding@cref}{{[subsection][1][3,5]5.1}{[1][31][]31}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3.1}{\ignorespaces Performance on syntactic contrasts using semantics-only retrieval strategies compared to full retrieval ($k=1$, $\tau =3$) of the child-realistic (top row) and large-scale (bottom row) models. Blue bars indicate high-frequency items and orange bars low-frequency items. We report the sequence-level retrieval given that it yields the best test performance. }}{32}{figure.caption.52}\protected@file@percent }
\newlabel{fig:context_effects_seq}{{3.1}{32}{Performance on syntactic contrasts using semantics-only retrieval strategies compared to full retrieval ($k=1$, $\tau =3$) of the child-realistic (top row) and large-scale (bottom row) models. Blue bars indicate high-frequency items and orange bars low-frequency items. We report the sequence-level retrieval given that it yields the best test performance}{figure.caption.52}{}}
\newlabel{fig:context_effects_seq@cref}{{[figure][1][3]3.1}{[1][31][]32}{}{}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {5.2}Effects of Retrieval Configuration}{32}{subsection.3.5.2}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {3.2}{\ignorespaces Performance on syntactic contrasts using semantics-only retrieval strategies compared to full retrieval ($k=1$, $\tau =3$) of the child-realistic (top row) and large-scale (bottom row) models. Blue bars indicate high-frequency items and orange bars low-frequency items. We report the phrase-level retrieval here. }}{33}{figure.caption.53}\protected@file@percent }
\newlabel{fig:context_effects_phrase}{{3.2}{33}{Performance on syntactic contrasts using semantics-only retrieval strategies compared to full retrieval ($k=1$, $\tau =3$) of the child-realistic (top row) and large-scale (bottom row) models. Blue bars indicate high-frequency items and orange bars low-frequency items. We report the phrase-level retrieval here}{figure.caption.53}{}}
\newlabel{fig:context_effects_phrase@cref}{{[figure][2][3]3.2}{[1][31][]33}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3.3}{\ignorespaces Performance on syntactic contrasts using semantics-only retrieval strategies compared to full retrieval ($k=1$, $\tau =3$) of the child-realistic (top row) and large-scale (bottom row) models. Blue bars indicate high-frequency items and orange bars low-frequency items. We report the token-level retrieval here. }}{34}{figure.caption.54}\protected@file@percent }
\newlabel{fig:structural_overlap_with_struc}{{3.3}{34}{Performance on syntactic contrasts using semantics-only retrieval strategies compared to full retrieval ($k=1$, $\tau =3$) of the child-realistic (top row) and large-scale (bottom row) models. Blue bars indicate high-frequency items and orange bars low-frequency items. We report the token-level retrieval here}{figure.caption.54}{}}
\newlabel{fig:structural_overlap_with_struc@cref}{{[figure][3][3]3.3}{[1][31][]34}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3.4}{\ignorespaces Performance when retrieved sequences contain target syntactic structures (with) versus when they do not (without). Top row: child-scale model; bottom row: large-scale model ($k=1$, $\tau =3$, sequence-level). Within each panel, the $x$-axis shows three conditions: \textbf  {base} (no retrieval), \textbf  {w/o+r $\rightarrow $ w/o} (retrieval from a non-structural datastore, random vs.\ embedding-similarity), and \textbf  {w/+r $\rightarrow $ w/} (retrieval from a structural datastore, random vs.\ embedding-similarity). Solid bars denote random retrieval (\textbf  {+r}); hatched segments denote the additional gain from embedding-similarity retrieval over random. Blue and orange bars correspond to high- and low-frequency items, respectively. Random retrieval baselines isolate the contribution of structural match in the datastore from semantic ranking by the retriever.}}{34}{figure.caption.55}\protected@file@percent }
\newlabel{fig:datastore}{{3.4}{34}{Performance when retrieved sequences contain target syntactic structures (with) versus when they do not (without). Top row: child-scale model; bottom row: large-scale model ($k=1$, $\tau =3$, sequence-level). Within each panel, the $x$-axis shows three conditions: \textbf {base} (no retrieval), \textbf {w/o+r $\rightarrow $ w/o} (retrieval from a non-structural datastore, random vs.\ embedding-similarity), and \textbf {w/+r $\rightarrow $ w/} (retrieval from a structural datastore, random vs.\ embedding-similarity). Solid bars denote random retrieval (\textbf {+r}); hatched segments denote the additional gain from embedding-similarity retrieval over random. Blue and orange bars correspond to high- and low-frequency items, respectively. Random retrieval baselines isolate the contribution of structural match in the datastore from semantic ranking by the retriever}{figure.caption.55}{}}
\newlabel{fig:datastore@cref}{{[figure][4][3]3.4}{[1][32][]34}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3.5}{\ignorespaces Performance across retrieval granularities (token, phrase, sequence) in child-realistic (top row) and large-scale (bottom row) models ($k=1$, $\tau =3$). Blue bars indicate high-frequency items and orange bars low-frequency items. Optimal granularity varies by phenomenon and frequency: sequence-level retrieval generally performs best for low-frequency items in wh-questions and relative clauses, while patterns for subject-verb agreement vary by model scale.}}{35}{figure.caption.56}\protected@file@percent }
\newlabel{fig:granularity}{{3.5}{35}{Performance across retrieval granularities (token, phrase, sequence) in child-realistic (top row) and large-scale (bottom row) models ($k=1$, $\tau =3$). Blue bars indicate high-frequency items and orange bars low-frequency items. Optimal granularity varies by phenomenon and frequency: sequence-level retrieval generally performs best for low-frequency items in wh-questions and relative clauses, while patterns for subject-verb agreement vary by model scale}{figure.caption.56}{}}
\newlabel{fig:granularity@cref}{{[figure][5][3]3.5}{[1][32][]35}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3.6}{\ignorespaces Performance across different context windows of the child-realistic (top row) and large-scale (bottom row) models. Blue bars indicate high-frequency items and orange bars low-frequency items. We report the sequence-level retrieval given that it yields the best test performance. Overall, larger context windows ($\tau = 10$) tend to yield stronger performance, especially for structurally complex phenomena, whereas simpler dependencies are less sensitive to context size. }}{35}{figure.caption.57}\protected@file@percent }
\newlabel{fig:context_effects_tau}{{3.6}{35}{Performance across different context windows of the child-realistic (top row) and large-scale (bottom row) models. Blue bars indicate high-frequency items and orange bars low-frequency items. We report the sequence-level retrieval given that it yields the best test performance. Overall, larger context windows ($\tau = 10$) tend to yield stronger performance, especially for structurally complex phenomena, whereas simpler dependencies are less sensitive to context size}{figure.caption.57}{}}
\newlabel{fig:context_effects_tau@cref}{{[figure][6][3]3.6}{[1][33][]35}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3.7}{\ignorespaces Performance across different numbers of retrieved neighbors of the child-realistic (top row) and large-scale (bottom row) models. Blue bars indicate high-frequency items and orange bars low-frequency items. We report the sequence-level retrieval given that it yields the best test performance. Performance exhibits a non-monotonic pattern: increasing the number of neighbors from $k=1$ to a moderate value ($k=16$) generally improves performance across phenomena and frequency bands, while further increasing to large values ($k=1024$) leads to degradation.}}{36}{figure.caption.58}\protected@file@percent }
\newlabel{fig:neighbor_effects}{{3.7}{36}{Performance across different numbers of retrieved neighbors of the child-realistic (top row) and large-scale (bottom row) models. Blue bars indicate high-frequency items and orange bars low-frequency items. We report the sequence-level retrieval given that it yields the best test performance. Performance exhibits a non-monotonic pattern: increasing the number of neighbors from $k=1$ to a moderate value ($k=16$) generally improves performance across phenomena and frequency bands, while further increasing to large values ($k=1024$) leads to degradation}{figure.caption.58}{}}
\newlabel{fig:neighbor_effects@cref}{{[figure][7][3]3.7}{[1][33][]36}{}{}{}}
