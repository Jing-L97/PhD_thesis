\@writefile{lot}{\contentsline {table}{\numberline {3.1}{\ignorespaces Syntactic contrast accuracy and perplexity (PPL) for baseline and kNN-LM models ($k=1$, $\tau =3$, sequence-level retrieval). kNN augmentation improves accuracy across all phenomena and both pretraining scales, with relative clauses showing the largest gains. Perplexity reductions are larger for the large-scale model. Bold indicates improvement over baseline.}}{30}{table.caption.50}\protected@file@percent }
\newlabel{tab:general_effects}{{3.1}{30}{Syntactic contrast accuracy and perplexity (PPL) for baseline and kNN-LM models ($k=1$, $\tau =3$, sequence-level retrieval). kNN augmentation improves accuracy across all phenomena and both pretraining scales, with relative clauses showing the largest gains. Perplexity reductions are larger for the large-scale model. Bold indicates improvement over baseline}{table.caption.50}{}}
\newlabel{tab:general_effects@cref}{{[table][1][3]3.1}{[1][29][]30}{}{}{}}
