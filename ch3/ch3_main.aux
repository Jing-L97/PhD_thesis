\newlabel{tab:model_architecture}{{3.4}{39}{Model architecture specifications. GPT-2 Small was trained from scratch on child-realistic data (50M words); GPT-2 XL uses the publicly released pretrained checkpoint from \citet {radford2019language} trained on WebText ($\sim $40GB)}{table.caption.60}{}}
\newlabel{tab:model_architecture@cref}{{[table][4][3]3.4}{[1][39][]39}{}{}{}}
