\newlabel{tab:training_hyperparameters}{{3.5}{40}{Training hyperparameters for GPT-2 Small on the child-realistic corpus, trained for 10 epochs using a standard autoregressive language modeling objective with cross-entropy loss}{table.caption.61}{}}
