\@writefile{lot}{\contentsline {table}{\numberline {3.7}{\ignorespaces Performance by retrieval granularity at $\tau \in \{3, 10\}$ with $k=16$ for child-realistic and GPT-2 XL models. Sequence-level retrieval consistently yields the strongest gains for low-frequency items in wh-questions and relative clauses across both model scales and context sizes.}}{43}{table.caption.63}\protected@file@percent }
\newlabel{tab:syntactic_granularity_with_k}{{3.7}{43}{Performance by retrieval granularity at $\tau \in \{3, 10\}$ with $k=16$ for child-realistic and GPT-2 XL models. Sequence-level retrieval consistently yields the strongest gains for low-frequency items in wh-questions and relative clauses across both model scales and context sizes}{table.caption.63}{}}
\newlabel{tab:syntactic_granularity_with_k@cref}{{[table][7][3]3.7}{[1][42][]43}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3.8}{\ignorespaces Effect of context window size ($\tau \in \{1,3,10\}$) for GPT-2 XL at $k=1$. Larger context windows benefit low-frequency items more than high-frequency items, particularly for sequence-level retrieval and structurally complex phenomena (Wh, RCs). Subject-verb agreement is less sensitive to context size.}}{44}{figure.caption.64}\protected@file@percent }
\newlabel{fig:app_context_gpt2xl_k1}{{3.8}{44}{Effect of context window size ($\tau \in \{1,3,10\}$) for GPT-2 XL at $k=1$. Larger context windows benefit low-frequency items more than high-frequency items, particularly for sequence-level retrieval and structurally complex phenomena (Wh, RCs). Subject-verb agreement is less sensitive to context size}{figure.caption.64}{}}
\newlabel{fig:app_context_gpt2xl_k1@cref}{{[figure][8][3]3.8}{[1][42][]44}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3.9}{\ignorespaces Effect of context window size ($\tau \in \{1,3,10\}$) for GPT-2 XL at $k=1024$. Compared to $k=1$, performance degrades substantially for low-frequency items, most severely for sequence-level retrieval, confirming that over-retrieval introduces noise that context window size cannot compensate for.}}{45}{figure.caption.65}\protected@file@percent }
\newlabel{fig:app_context_gpt2xl_k1024}{{3.9}{45}{Effect of context window size ($\tau \in \{1,3,10\}$) for GPT-2 XL at $k=1024$. Compared to $k=1$, performance degrades substantially for low-frequency items, most severely for sequence-level retrieval, confirming that over-retrieval introduces noise that context window size cannot compensate for}{figure.caption.65}{}}
\newlabel{fig:app_context_gpt2xl_k1024@cref}{{[figure][9][3]3.9}{[1][42][]45}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3.10}{\ignorespaces Effect of context window size ($\tau \in \{1,3,10\}$) for the child-realistic model at $k=1$. Patterns are qualitatively similar to GPT-2 XL (Figure~\ref {fig:app_context_gpt2xl_k1}) but with smaller absolute gains, consistent with the smaller model's weaker parametric representations.}}{46}{figure.caption.66}\protected@file@percent }
\newlabel{fig:app_context_child_k1}{{3.10}{46}{Effect of context window size ($\tau \in \{1,3,10\}$) for the child-realistic model at $k=1$. Patterns are qualitatively similar to GPT-2 XL (Figure~\ref {fig:app_context_gpt2xl_k1}) but with smaller absolute gains, consistent with the smaller model's weaker parametric representations}{figure.caption.66}{}}
\newlabel{fig:app_context_child_k1@cref}{{[figure][10][3]3.10}{[1][42][]46}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3.11}{\ignorespaces Effect of context window size ($\tau \in \{1,3,10\}$) for the child-realistic model at $k=1024$. Performance degradation at large $k$ is more pronounced than for GPT-2 XL, particularly for low-frequency RCs, suggesting the smaller model is more susceptible to retrieval noise.}}{47}{figure.caption.67}\protected@file@percent }
\newlabel{fig:app_context_child_k1024}{{3.11}{47}{Effect of context window size ($\tau \in \{1,3,10\}$) for the child-realistic model at $k=1024$. Performance degradation at large $k$ is more pronounced than for GPT-2 XL, particularly for low-frequency RCs, suggesting the smaller model is more susceptible to retrieval noise}{figure.caption.67}{}}
\newlabel{fig:app_context_child_k1024@cref}{{[figure][11][3]3.11}{[1][42][]47}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3.12}{\ignorespaces Effect of number of retrieved neighbors ($k \in \{1,16,1024\}$) for GPT-2 XL at $\tau =1$. The non-monotonic pattern holds: $k=16$ outperforms both $k=1$ and $k=1024$ across most conditions, with degradation at large $k$ most severe for sequence-level retrieval and low-frequency items.}}{48}{figure.caption.68}\protected@file@percent }
\newlabel{fig:app_neighbor_gpt2xl_tau1}{{3.12}{48}{Effect of number of retrieved neighbors ($k \in \{1,16,1024\}$) for GPT-2 XL at $\tau =1$. The non-monotonic pattern holds: $k=16$ outperforms both $k=1$ and $k=1024$ across most conditions, with degradation at large $k$ most severe for sequence-level retrieval and low-frequency items}{figure.caption.68}{}}
\newlabel{fig:app_neighbor_gpt2xl_tau1@cref}{{[figure][12][3]3.12}{[1][42][]48}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3.13}{\ignorespaces Effect of number of retrieved neighbors ($k \in \{1,16,1024\}$) for GPT-2 XL at $\tau =3$. Results are consistent with $\tau =1$ (Figure~\ref {fig:app_neighbor_gpt2xl_tau1}): $k=16$ provides the best balance between evidence aggregation and noise across phenomena and frequency bands.}}{49}{figure.caption.69}\protected@file@percent }
\newlabel{fig:app_neighbor_gpt2xl_tau3}{{3.13}{49}{Effect of number of retrieved neighbors ($k \in \{1,16,1024\}$) for GPT-2 XL at $\tau =3$. Results are consistent with $\tau =1$ (Figure~\ref {fig:app_neighbor_gpt2xl_tau1}): $k=16$ provides the best balance between evidence aggregation and noise across phenomena and frequency bands}{figure.caption.69}{}}
\newlabel{fig:app_neighbor_gpt2xl_tau3@cref}{{[figure][13][3]3.13}{[1][42][]49}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3.14}{\ignorespaces Effect of number of retrieved neighbors ($k \in \{1,16,1024\}$) for the child-realistic model at $\tau =1$. The non-monotonic pattern holds across both model scales, with $k=16$ providing the best overall performance and $k=1024$ degrading most severely for low-frequency RCs.}}{50}{figure.caption.70}\protected@file@percent }
\newlabel{fig:app_neighbor_child_tau1}{{3.14}{50}{Effect of number of retrieved neighbors ($k \in \{1,16,1024\}$) for the child-realistic model at $\tau =1$. The non-monotonic pattern holds across both model scales, with $k=16$ providing the best overall performance and $k=1024$ degrading most severely for low-frequency RCs}{figure.caption.70}{}}
\newlabel{fig:app_neighbor_child_tau1@cref}{{[figure][14][3]3.14}{[1][42][]50}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3.15}{\ignorespaces Effect of number of retrieved neighbors ($k \in \{1,16,1024\}$) for the child-realistic model at $\tau =3$. Consistent with all other configurations, $k=16$ provides the best balance between evidence aggregation and noise, with gains most pronounced for low-frequency RCs and Wh-questions.}}{51}{figure.caption.71}\protected@file@percent }
\newlabel{fig:app_neighbor_child_tau3}{{3.15}{51}{Effect of number of retrieved neighbors ($k \in \{1,16,1024\}$) for the child-realistic model at $\tau =3$. Consistent with all other configurations, $k=16$ provides the best balance between evidence aggregation and noise, with gains most pronounced for low-frequency RCs and Wh-questions}{figure.caption.71}{}}
\newlabel{fig:app_neighbor_child_tau3@cref}{{[figure][15][3]3.15}{[1][42][]51}{}{}{}}
