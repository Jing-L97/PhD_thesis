\contentsline {xchapter}{Expressive vocabulary growth in children and LMs}{5}{chapter.2}%
\contentsline {figure}{\numberline {2.1}{\ignorespaces \textbf {Overview of the \textsc {corpus-CDI}{} benchmark framework.} (a) Training and generation sizes are aligned with age-appropriate estimates of linguistic exposure and production from 6–36 months \citep {cristia2019child}. (b) Evaluation sets match the frequency distribution of MacArthur–Bates CDI words in child-directed speech (English-CHILDES).}}{8}{figure.caption.17}%
\contentsline {figure}{\numberline {2.2}{\ignorespaces \textbf {Core metrics comparing child and model vocabulary development across age groups.} Left: Type–token ratio (TTR) measuring lexical diversity. Middle: Non-word type rate indicating the proportion of invalid word forms. Right: \textsc {corpus-CDI}{} scores tracking vocabulary acquisition (words counted as known if produced $>$60 times). Results are shown for LSTM and Transformer models trained on audiobooks and child-directed speech (CDS), compared with CHILDES child production data. Error bars denote 95\% confidence intervals across disjoint training subsets. For the final months (32–36), outputs are generated from the same model checkpoint and shown with lighter transparency.}}{11}{figure.caption.28}%
\contentsline {figure}{\numberline {2.3}{\ignorespaces \textbf {Temperature trade-off across different metrics; temperature settings (0.3-1.5)} Left: Trade-off between type-token ratio and CDI score. Right: Relationship between non-word rate and CDI score. Points show mean scores across models, with numbers illustrating temperature values.}}{12}{figure.caption.29}%
\contentsline {figure}{\numberline {2.4}{\ignorespaces \textbf {Extrapolated months across different datasets for models trained on audiobooks}. x-axis: log frequency per million in training data; y-axis:estimated developmental month at which models reach 80\% mastery for each frequency band. Missing points of the lower frequency bands of temperature =0.3 come from 0 }}{14}{figure.caption.35}%
\contentsline {figure}{\numberline {2.5}{\ignorespaces \textbf {Proportion of content words in generated text across development.} Children show an inverse U-shaped trajectory, while all model configurations maintain stable proportions around 40\% across training stages.}}{15}{figure.caption.39}%
\contentsline {figure}{\numberline {2.6}{\ignorespaces \textbf {Count-based calibration} Comparison of different word frequency thresholds for determining word acquisition. The optimal threshold (60 occurrences) was selected based on alignment with parental vocabulary size reports (red line). Each threshold produces distinct vocabulary growth trajectories, with higher thresholds resulting in more conservative estimates.}}{22}{figure.caption.47}%
\contentsline {figure}{\numberline {2.7}{\ignorespaces \textbf {Word count distribution(temperature = 1.0)}.Word frequency relationships between training and generation sets under different sampling conditions (1x, 10x, 100x generation volume). x-axis: word frequency in the training set; y-axis: word frequency in the generation set. Side plot on the bottom show Missing rates as a function of word count in input corpus.}}{23}{figure.caption.48}%
\contentsline {figure}{\numberline {2.8}{\ignorespaces \textbf {Model vocabulary growth across estimated annual exposure levels.} Comparison of \textsc {corpus-CDI}{} trajectories for models trained on 100-, 500-, and 1000-hour exposure estimates, alongside CHILDES child production data. Models show roughly linear vocabulary growth that scales modestly with total exposure but remains far below the human developmental curve. }}{24}{figure.caption.49}%
\addvspace {10\p@ }
\contentsline {xchapter}{Episodic memory and the lexical frequency gap}{25}{chapter.3}%
\contentsline {figure}{\numberline {3.1}{\ignorespaces Performance on syntactic contrasts using semantics-only retrieval strategies compared to full retrieval ($k=1$, $\tau =3$) of the child-realistic (top row) and large-scale (bottom row) models. Blue bars indicate high-frequency items and orange bars low-frequency items. We report the sequence-level retrieval given that it yields the best test performance. }}{32}{figure.caption.52}%
\contentsline {figure}{\numberline {3.2}{\ignorespaces Performance on syntactic contrasts using semantics-only retrieval strategies compared to full retrieval ($k=1$, $\tau =3$) of the child-realistic (top row) and large-scale (bottom row) models. Blue bars indicate high-frequency items and orange bars low-frequency items. We report the phrase-level retrieval here. }}{33}{figure.caption.53}%
\contentsline {figure}{\numberline {3.3}{\ignorespaces Performance on syntactic contrasts using semantics-only retrieval strategies compared to full retrieval ($k=1$, $\tau =3$) of the child-realistic (top row) and large-scale (bottom row) models. Blue bars indicate high-frequency items and orange bars low-frequency items. We report the token-level retrieval here. }}{34}{figure.caption.54}%
\contentsline {figure}{\numberline {3.4}{\ignorespaces Performance when retrieved sequences contain target syntactic structures (with) versus when they do not (without). Top row: child-scale model; bottom row: large-scale model ($k=1$, $\tau =3$, sequence-level). Within each panel, the $x$-axis shows three conditions: \textbf {base} (no retrieval), \textbf {w/o+r $\rightarrow $ w/o} (retrieval from a non-structural datastore, random vs.\ embedding-similarity), and \textbf {w/+r $\rightarrow $ w/} (retrieval from a structural datastore, random vs.\ embedding-similarity). Solid bars denote random retrieval (\textbf {+r}); hatched segments denote the additional gain from embedding-similarity retrieval over random. Blue and orange bars correspond to high- and low-frequency items, respectively. Random retrieval baselines isolate the contribution of structural match in the datastore from semantic ranking by the retriever.}}{34}{figure.caption.55}%
\contentsline {figure}{\numberline {3.5}{\ignorespaces Performance across retrieval granularities (token, phrase, sequence) in child-realistic (top row) and large-scale (bottom row) models ($k=1$, $\tau =3$). Blue bars indicate high-frequency items and orange bars low-frequency items. Optimal granularity varies by phenomenon and frequency: sequence-level retrieval generally performs best for low-frequency items in wh-questions and relative clauses, while patterns for subject-verb agreement vary by model scale.}}{35}{figure.caption.56}%
\contentsline {figure}{\numberline {3.6}{\ignorespaces Performance across different context windows of the child-realistic (top row) and large-scale (bottom row) models. Blue bars indicate high-frequency items and orange bars low-frequency items. We report the sequence-level retrieval given that it yields the best test performance. Overall, larger context windows ($\tau = 10$) tend to yield stronger performance, especially for structurally complex phenomena, whereas simpler dependencies are less sensitive to context size. }}{35}{figure.caption.57}%
\contentsline {figure}{\numberline {3.7}{\ignorespaces Performance across different numbers of retrieved neighbors of the child-realistic (top row) and large-scale (bottom row) models. Blue bars indicate high-frequency items and orange bars low-frequency items. We report the sequence-level retrieval given that it yields the best test performance. Performance exhibits a non-monotonic pattern: increasing the number of neighbors from $k=1$ to a moderate value ($k=16$) generally improves performance across phenomena and frequency bands, while further increasing to large values ($k=1024$) leads to degradation.}}{36}{figure.caption.58}%
\contentsline {figure}{\numberline {3.8}{\ignorespaces Effect of context window size ($\tau \in \{1,3,10\}$) for GPT-2 XL at $k=1$. Larger context windows benefit low-frequency items more than high-frequency items, particularly for sequence-level retrieval and structurally complex phenomena (Wh, RCs). Subject-verb agreement is less sensitive to context size.}}{44}{figure.caption.64}%
\contentsline {figure}{\numberline {3.9}{\ignorespaces Effect of context window size ($\tau \in \{1,3,10\}$) for GPT-2 XL at $k=1024$. Compared to $k=1$, performance degrades substantially for low-frequency items, most severely for sequence-level retrieval, confirming that over-retrieval introduces noise that context window size cannot compensate for.}}{45}{figure.caption.65}%
\contentsline {figure}{\numberline {3.10}{\ignorespaces Effect of context window size ($\tau \in \{1,3,10\}$) for the child-realistic model at $k=1$. Patterns are qualitatively similar to GPT-2 XL (Figure~\ref {fig:app_context_gpt2xl_k1}) but with smaller absolute gains, consistent with the smaller model's weaker parametric representations.}}{46}{figure.caption.66}%
\contentsline {figure}{\numberline {3.11}{\ignorespaces Effect of context window size ($\tau \in \{1,3,10\}$) for the child-realistic model at $k=1024$. Performance degradation at large $k$ is more pronounced than for GPT-2 XL, particularly for low-frequency RCs, suggesting the smaller model is more susceptible to retrieval noise.}}{47}{figure.caption.67}%
\contentsline {figure}{\numberline {3.12}{\ignorespaces Effect of number of retrieved neighbors ($k \in \{1,16,1024\}$) for GPT-2 XL at $\tau =1$. The non-monotonic pattern holds: $k=16$ outperforms both $k=1$ and $k=1024$ across most conditions, with degradation at large $k$ most severe for sequence-level retrieval and low-frequency items.}}{48}{figure.caption.68}%
\contentsline {figure}{\numberline {3.13}{\ignorespaces Effect of number of retrieved neighbors ($k \in \{1,16,1024\}$) for GPT-2 XL at $\tau =3$. Results are consistent with $\tau =1$ (Figure~\ref {fig:app_neighbor_gpt2xl_tau1}): $k=16$ provides the best balance between evidence aggregation and noise across phenomena and frequency bands.}}{49}{figure.caption.69}%
\contentsline {figure}{\numberline {3.14}{\ignorespaces Effect of number of retrieved neighbors ($k \in \{1,16,1024\}$) for the child-realistic model at $\tau =1$. The non-monotonic pattern holds across both model scales, with $k=16$ providing the best overall performance and $k=1024$ degrading most severely for low-frequency RCs.}}{50}{figure.caption.70}%
\contentsline {figure}{\numberline {3.15}{\ignorespaces Effect of number of retrieved neighbors ($k \in \{1,16,1024\}$) for the child-realistic model at $\tau =3$. Consistent with all other configurations, $k=16$ provides the best balance between evidence aggregation and noise, with gains most pronounced for low-frequency RCs and Wh-questions.}}{51}{figure.caption.71}%
\addvspace {10\p@ }
\contentsline {xchapter}{LLMs and caregiver feedback}{52}{chapter.4}%
\contentsline {figure}{\numberline {4.1}{\ignorespaces Developmental trajectories of six linguistic/conversational features in children and LLMs. We compare actual human data from the child-caregiver dataset CHILDES vs. LLMs playing a child. Models include two LLMs (GPT-4o, Llama 3) in zero-shot and 3-shot settings. Points represent averages across all utterances and conversations, and ranges represent 95\% confidence intervals.}}{57}{figure.caption.76}%
\contentsline {figure}{\numberline {4.2}{\ignorespaces Developmental trajectories of six linguistic/conversational features in caregivers and LLMs. We compare actual human data from the child-caregiver dataset CHILDES vs. LLMs playing a caregiver. Models include two LLMs (GPT-4o, Llama 3) in zero-shot and 3-shot settings. Points represent averages across all utterances and conversations, and ranges represent 95\% confidence intervals.}}{58}{figure.caption.77}%
\contentsline {figure}{\numberline {4.3}{\ignorespaces Comparison of linguistic/conversational features across the single-turn and multi-turn testing for children. The bars show the averages across age groups. The points show variability across conversations (40 in total). Models include two LLMs (GPT-4o, Llama 3) in zero-shot and 3-shot settings. ``BB\_tuned'' which stands for the BlenderBot model fine-tuned on a subset of CHILDES. Finally, for CHILDES, the data for single-turn and multi-turn is the same.}}{60}{figure.caption.79}%
\contentsline {figure}{\numberline {4.4}{\ignorespaces Comparison of linguistic/conversational features across the single-turn and multi-turn testing for caregivers. The bars show the averages across age groups. The points show variability across conversations (40 in total). Models include two LLMs (GPT-4o, Llama 3) in zero-shot and 3-shot settings. Finally, for CHILDES, the data for single-turn and multi-turn is the same.}}{61}{figure.caption.80}%
\contentsline {figure}{\numberline {4.5}{\ignorespaces Generated-utterance grammaticality across pretraining scales for each reward. The top row shows results from the CHILDES-adapted ChildCG classifier, while the bottom row shows results using a standard GEC-based metric. Within each panel, baseline and topline trajectories are repeated to make the reward trajectory directly comparable. Means are computed over training seeds units after averaging over generation seeds. Error bars show $\pm 1$ standard deviation across training seeds. }}{71}{figure.caption.96}%
\contentsline {figure}{\numberline {4.6}{\ignorespaces Baseline and Topline performance across pretraining scales. The top row reports minimal-pair benchmark accuracy for Zorro and BLiMP. The bottom row reports grammaticality of generated utterances, using the ChildCG or GEC-based metric. Points show means across trainings seeds (after averaging over generation seeds). Error bars show ±1 standard deviation across these independent units. }}{76}{figure.4.6}%
\contentsline {figure}{\numberline {4.7}{\ignorespaces Benchmark performance across pretraining scales for each reward family. Rows show Zorro and BLiMP minimal-pair accuracy; columns show the four empirical reward families. Within each panel, the baseline and topline trajectories are repeated to make the reward trajectory directly comparable at each scale. Means are computed over training seeds, after averaging over generation seeds. Error bars show $\pm 1$ standard deviation across independent units. }}{77}{figure.caption.101}%
\contentsline {figure}{\numberline {4.8}{\ignorespaces Properties of generated utterances: Sentence length, pooled lexical entropy, function-word density, and rate of non-words. Points show means for each reward across training seeds, with error bars indicating $\pm 1$ standard deviation across these seeds. Within each panel, baseline and topline trajectories are repeated to make the reward trajectory directly comparable at each scale. }}{78}{figure.caption.102}%
