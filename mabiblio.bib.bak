	title = {Shared {Neural} {Mechanisms} of {Visual} {Perception} and {Imagery}},
	volume = {23},
	issn = {13646613},
	url = {https://linkinghub.elsevier.com/retrieve/pii/S1364661319300592},
	doi = {10.1016/j.tics.2019.02.004},
	language = {en},
