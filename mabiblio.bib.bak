	pages = {49--61},
}

@book{austin_how_1975,
	title = {How to {Do} {Things} with {Words}},
	isbn = {978-0-19-824553-7},
	abstract = {This work sets out Austin's conclusions in the field to which he directed his main efforts for at least the last ten years of his life. Starting from an exhaustive examination of his already well-known distinction between performative utterances and statements, Austin here finally abandons that distinction, replacing it with a more general theory of 'illocutionary forces' of utterances which has important bearings on a wide variety of philosophicalproblems.},
	language = {en},
	publisher = {Clarendon Press},
	author = {Austin, John Langshaw},
	year = {1975},
	note = {Google-Books-ID: XnRkQSTUpmgC},
}

