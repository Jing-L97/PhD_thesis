@article{miller_relation_1981,
	title = {The relation between age and mean length of utterance in morphemes},
	volume = {24},
	issn = {0022-4685},
	doi = {10.1044/jshr.2402.154},
	abstract = {The relationship between child age and mean length of utterance (MLU) measured in morphemes was studied in 123 middle- to upper-middle-class midwestern children (aged 17–59 mo) conversing with mothers in free play. A significant correlation was found between age and MLU. Age accounted for 78\% of the variance when MLU was regressed on age, and MLU accounted for 77\% of the variance when age was regressed on MLU. Ranges within 1 standard deviation were estimated for predicted MLUs and derived for predicted ages on the basis of linear regression. MLU increased at an average rate of 1.2 morphemes/yr; predicted variability in predicted MLU increased with age. (26 ref) (PsycINFO Database Record (c) 2017 APA, all rights reserved)},
	number = {2},
	journal = {Journal of Speech \& Hearing Research},
	author = {Miller, Jon F. and Chapman, Robin S.},
	year = {1981},
	note = {Place: US
Publisher: American Speech-Language-Hearing Assn},
	keywords = {Morphemes, Speech Characteristics, Speech Development},
	pages = {154--161},
}

