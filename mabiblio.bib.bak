	title = {A {Computational} {Foundation} for the {Study} of {Cognition}},
	volume = {12},
	issn = {1598-2327},
	url = {https://oak.go.kr/central/journallist/journaldetail.do?article_seq=18672},
	abstract = {A Computational Foundation for the Study of Cognition{\textless}xref ref-type="corresp" rid="cor1"{\textgreater}*{\textless}/xref{\textgreater} - computation;cognition;implementation;explanation;connectionism;computationalism;representation;artificial intelligence},
