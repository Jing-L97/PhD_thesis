	year = {2021},
	pages = {1968--1994},
}

@inproceedings{roberts_language_2016,
	title = {Language adapts to interaction},
	booktitle = {Proceedings of {EvoLang} {XI}, {Language} {Adapts} to {Interaction} {Workshop}},
	author = {Roberts, Seán and Mills, Gregory J.},
