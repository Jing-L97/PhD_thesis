	address = {Online and Punta Cana, Dominican Republic},
	title = {{COVR}: {A} {Test}-{Bed} for {Visually} {Grounded} {Compositional} {Generalization} with {Real} {Images}},
	shorttitle = {{COVR}},
	url = {https://aclanthology.org/2021.emnlp-main.774},
