	title = {The neuroconnectionist research programme},
	volume = {24},
	issn = {1471-003X, 1471-0048},
	url = {https://www.nature.com/articles/s41583-023-00705-w},
	doi = {10.1038/s41583-023-00705-w},
	language = {en},
