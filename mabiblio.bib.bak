	url = {https://books.google.com/books?hl=en&lr=&id=KXU8DwAAQBAJ&oi=fnd&pg=PR11&dq=Harris,+Randy+Allen.+1993.+The+Linguistics+Wars&ots=BEJnMisOSU&sig=gcVJe3iIDZBRymM1pRTr3KcGpDg},
